# CapitAI Backend Environment Configurations
PORT=5000

# Connection configurations (Uncomment and set if using live instances)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/capitai
# REDIS_URL=redis://localhost:6379

# LLM Providers (Uncomment and set to switch from offline emulator to live LLMs)
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# Live Stock Market API Integrations (Uncomment to override mock streams)
# FINNHUB_KEY=your-finnhub-key
# ALPHA_VANTAGE_KEY=your-alpha-vantage-key
# POLYGON_KEY=your-polygon-key

# Nodemailer SMTP Mail Delivery (Uncomment and set to send real email codes)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-google-app-password

